# =============================================
# Web3 Job Hunter Bot — Environment Variables
# =============================================
# Copy this file to .env and fill in your values

# --- REQUIRED ---
# Get from @BotFather on Telegram
BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram Chat ID (send /start to @userinfobot to get it)
CHAT_ID=your_chat_id_here

# --- OPTIONAL (has defaults) ---
# Minimum market cap in USD to alert on (default: 4000)
MIN_MCAP_USD=4000

# How often to scan for new tokens in seconds (default: 60)
SCAN_INTERVAL_SECONDS=60

# How often to check whale wallets in seconds (default: 30)
WHALE_CHECK_INTERVAL_SECONDS=30

# Whale alert threshold in USD (default: 10000)
WHALE_BUY_THRESHOLD_USD=10000
WHALE_SELL_THRESHOLD_USD=10000

# --- RPC ENDPOINTS (free public nodes pre-filled) ---
SOLANA_RPC=https://api.mainnet-beta.solana.com
ETH_RPC=https://eth.llamarpc.com
BSC_RPC=https://bsc-dataseed.binance.org
BASE_RPC=https://mainnet.base.org
