# =============================================
# Web3 Job Hunter Bot — Environment Variables
# =============================================

# --- REQUIRED ---
BOT_TOKEN=your_telegram_bot_token_here
CHAT_ID=your_chat_id_here

# --- MULTI-USER: add friends' chat IDs here ---
# Comma-separated, no spaces
# Get their IDs: they send /start to @RawDataBot
EXTRA_CHAT_IDS=friend1_chat_id,friend2_chat_id

# --- OPTIONAL (has defaults) ---
MIN_MCAP_USD=4000
SCAN_INTERVAL_SECONDS=60
WHALE_CHECK_INTERVAL_SECONDS=30
PUMPFUN_INTERVAL_SECONDS=30
JOB_SCAN_INTERVAL_SECONDS=3600

WHALE_BUY_THRESHOLD_USD=10000
WHALE_SELL_THRESHOLD_USD=10000

# --- RPC ENDPOINTS ---
SOLANA_RPC=https://api.mainnet-beta.solana.com
ETH_RPC=https://eth.llamarpc.com
BSC_RPC=https://bsc-dataseed.binance.org
BASE_RPC=https://mainnet.base.org
